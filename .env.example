# ─── Backend (backend/.env) ───
# Required
GROQ_API_KEY=           # Groq AI inference (https://console.groq.com)
SEARCH_API_KEY=         # Tavily Search API (https://tavily.com)
NEWS_API_KEY=           # GNews API (https://gnews.io)

# Optional (with defaults)
PORT=3000               # Server port (default: 3000)
FRONTEND_URL=http://localhost:5173  # CORS origin (default: http://localhost:5173)

# ─── Frontend (frontend/.env) ───
VITE_API_URL=http://localhost:3000   # Backend API URL (default: https://battlecard-ai.onrender.com)
